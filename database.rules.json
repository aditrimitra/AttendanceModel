{
  "rules": {
    "regd_to_email": {
      ".read": true,
      ".write": "root.child('users').child(auth.uid).child('role').val() === 'master' || root.child('users').child(auth.uid).child('role').val() === 'admin'"
    },
    "users": {
      "$uid": {
        ".read": "auth != null",
        ".write": "root.child('users').child(auth.uid).child('role').val() === 'master' || root.child('users').child(auth.uid).child('role').val() === 'admin' || auth.uid === $uid"
      }
    },
    "attendance": {
      ".read": "auth != null",
      ".write": "root.child('users').child(auth.uid).child('role').val() === 'master' || root.child('users').child(auth.uid).child('role').val() === 'admin'"
    },
    "subjects": {
      ".read": "auth != null",
      ".write": "root.child('users').child(auth.uid).child('role').val() === 'master' || root.child('users').child(auth.uid).child('role').val() === 'admin'"
    },
    "timetable": {
      ".read": "auth != null",
      ".write": "root.child('users').child(auth.uid).child('role').val() === 'master' || root.child('users').child(auth.uid).child('role').val() === 'admin'"
    },
    "queries": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "roles": {
        ".read": "auth != null",
        ".write": "root.child('users').child(auth.uid).child('role').val() === 'master' || root.child('users').child(auth.uid).child('role').val() === 'admin'"
    }
  }
}
